meta {
  name: Signup
  type: http
  seq: 1
}

post {
  url: {{base_url}}{{api_prefix}}/auth/signup
  body: json
  auth: none
}

body:json {
  {
    "username": "developer",
    "password": "password",
    "password_confirmation": "password"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("access_token", res.body.access_token);
    bru.setEnvVar("refresh_token", res.body.refresh_token);
  }
}
